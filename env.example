# Copia questo file in .env e compila i valori
# NON committare mai il file .env su Git!

# PostgreSQL — Railway fornisce questa variabile automaticamente
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — scegli una stringa casuale lunga (es. openssl rand -hex 32)
JWT_SECRET=cambia_questa_stringa_con_qualcosa_di_sicuro

# Anthropic Claude API (usata solo dal server, non dal frontend)
ANTHROPIC_API_KEY=sk-ant-...

# Ambiente
NODE_ENV=development
